---
// ✅ [FEATURE]: GuideLayout — article wrapper for /guides (SEO + Article/FAQ schema + brand CTA).
// Goes at: src/layouts/GuideLayout.astro
import Base from './Base.astro';
import StoreButtons from '../components/StoreButtons.astro';
import { AUTHOR, HAVYU_LINKS, personId, personSchema } from '../data/author';

interface Props {
  title: string;
  displayTitle?: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  heroImageAlt?: string;
  tags?: string[];
  pillar?: boolean;
  faqs?: { q: string; a: string }[];
  slug: string;
}

const {
  title,
  displayTitle,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroImageAlt,
  tags = [],
  pillar = false,
  faqs = [],
  slug,
} = Astro.props;

const site = Astro.site ?? new URL('https://havyu.org');
const origin = site.origin;
const canonicalPath = `/guides/${slug}`;
const url = new URL(canonicalPath, site).href;

const published = pubDate.toISOString();
const modified = (updatedDate ?? pubDate).toISOString();
const dateLabel = (updatedDate ?? pubDate).toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// ✅ [FEATURE]: BlogPosting schema — author = the same Person entity as the site (E-E-A-T).
const articleSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: published,
  dateModified: modified,
  ...(heroImage ? { image: new URL(heroImage, site).href } : {}),
  author: { '@type': 'Person', '@id': personId(origin), name: AUTHOR.name, url: origin },
  publisher: {
    '@type': 'Organization',
    name: 'Havyu AI',
    url: origin,
    logo: { '@type': 'ImageObject', url: new URL('/apple-touch-icon.png', site).href },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  url,
};

const faqSchema =
  faqs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }
    : null;

const schema = [articleSchema, personSchema(origin), ...(faqSchema ? [faqSchema] : [])];

const h1 = displayTitle ?? title;
const ogImage = heroImage ?? '/og-image.png';
const ogAlt = heroImageAlt ?? 'Havyu AI — The AI Coach for Lifting Weights'; // ✅ [FIX]: locked tagline
---

<Base
  title={`${title} — Havyu`}
  description={description}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  ogImageAlt={ogAlt}
  ogType="article"
  schema={schema}
>
  <article class="mx-auto max-w-3xl px-6 py-12 md:py-16">
    <a href="/guides" class="text-sm font-semibold text-forest transition hover:text-forest-deep">
      ← All guides
    </a>

    <div class="mt-6 flex flex-wrap items-center gap-2">
      {pillar && (
        // ✅ [FIX]: was bg-ai/10 text-ai — this badge marks reading order, not
        // AI-generated content, so it shouldn't use the AI-reserved purple token.
        <span class="rounded-full bg-chestnut/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.14em] text-chestnut">
          Start here
        </span>
      )}
      {tags.map((t) => (
        <span class="rounded-full bg-surface px-3 py-1 text-xs font-semibold text-espresso/60 ring-1 ring-border">
          {t}
        </span>
      ))}
    </div>

    <h1 class="mt-4 font-display text-3xl font-black leading-tight tracking-tight text-espresso md:text-4xl">
      {h1}
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-espresso/70">{description}</p>

    <div class="mt-5 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-espresso/55">
      <span class="font-semibold text-espresso/75">{AUTHOR.name}</span>
      <span aria-hidden="true">·</span>
      <span>Developer of Havyu</span>
      <span aria-hidden="true">·</span>
      <time datetime={modified}>{dateLabel}</time>
    </div>

    {heroImage && (
      <img
        src={heroImage}
        alt={heroImageAlt ?? ''}
        width="1200"
        height="675"
        class="mt-8 aspect-[16/9] w-full rounded-3xl object-cover shadow-card"
      />
    )}

    <div class="guide-prose mt-10">
      <slot />
    </div>

    {faqs.length > 0 && (
      <section class="mt-14">
        <h2 class="font-display text-2xl font-black tracking-tight text-espresso">Common questions</h2>
        <div class="mt-5 divide-y divide-border overflow-hidden rounded-3xl border border-border bg-surface">
          {faqs.map((f) => (
            <details class="group p-5">
              <summary class="cursor-pointer list-none font-display text-lg font-bold text-espresso [&::-webkit-details-marker]:hidden">
                {f.q}
              </summary>
              <p class="mt-2 leading-relaxed text-espresso/70">{f.a}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    {/* ✅ [FEATURE]: brand CTA — Havyu voice sign-off */}
    <aside class="mt-14 rounded-3xl border-2 border-ai/20 bg-ai/5 p-8">
      {/* ✅ [FEATURE]: app-identity header — icon top-left beside the heading */}
      <div class="flex items-center gap-4">
        <img
          src="/apple-touch-icon.png"
          alt="Havyu app icon"
          width="56"
          height="56"
          loading="lazy"
          class="h-14 w-14 shrink-0 rounded-2xl shadow-card"
        />
        <div class="min-w-0">
          {/* ✅ [FIX]: was text-ai — this kicker is the ecosystem mantra, not
              AI-generated content, so it shouldn't use the AI-reserved purple token. */}
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-forest">Train. Recover. Progress.</p>
          <p class="font-display text-lg font-extrabold leading-tight text-espresso">Havyu AI</p>
        </div>
      </div>
      <p class="mt-5 text-lg leading-relaxed text-espresso/80">
        Havyu watches both sides of your progress — your training and your recovery — and
        connects the dots, so you can see the patterns behind your strength.
      </p>
      <div class="mt-6">
        <StoreButtons variant="onLight" appStoreUrl={HAVYU_LINKS.appStore} />
      </div>
      <a href="/" class="mt-4 inline-block text-sm font-semibold text-forest transition hover:text-forest-deep">
        How Havyu works →
      </a>
      <p class="mt-4 text-sm text-espresso/50">— Havyu, The AI Coach for Lifting Weights.</p>
    </aside>
  </article>
</Base>

<style is:global>
  .guide-prose {
    color: var(--color-espresso);
  }
  .guide-prose > * + * {
    margin-top: 1.15rem;
  }
  .guide-prose h2 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1.2;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--color-espresso);
    margin-top: 2.5rem;
  }
  .guide-prose h2 + p {
    margin-top: 0.75rem;
  }
  .guide-prose h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-espresso);
    margin-top: 1.75rem;
  }
  .guide-prose p {
    line-height: 1.75;
    color: rgba(62, 39, 35, 0.82);
  }
  .guide-prose a {
    color: var(--color-forest);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .guide-prose a:hover {
    color: var(--color-forest-deep);
  }
  .guide-prose strong {
    color: var(--color-espresso);
    font-weight: 700;
  }
  .guide-prose ul,
  .guide-prose ol {
    padding-left: 1.25rem;
    line-height: 1.75;
    color: rgba(62, 39, 35, 0.82);
  }
  .guide-prose ul {
    list-style: disc;
  }
  .guide-prose ol {
    list-style: decimal;
  }
  .guide-prose li + li {
    margin-top: 0.4rem;
  }
  .guide-prose hr {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin-top: 2.25rem;
  }
  .guide-prose blockquote {
    border-left: 3px solid var(--color-forest);
    padding-left: 1rem;
    color: rgba(62, 39, 35, 0.7);
    font-style: italic;
  }
</style>

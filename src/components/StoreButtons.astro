---
// ✅ [FEATURE]: Shared app-store buttons — Apple App Store badge + Google Play "coming soon".
// Used on the home hero (onDark) and the guides CTA (onLight) so both stay identical.
// Goes at: src/components/StoreButtons.astro
interface Props {
  variant?: 'onLight' | 'onDark';
  appStoreUrl: string;
}
const { variant = 'onLight', appStoreUrl } = Astro.props;

const appStoreClass = variant === 'onDark' ? 'bg-white text-forest' : 'bg-espresso text-white';
const playClass =
  variant === 'onDark' ? 'border-white/30 text-white/80' : 'border-border text-espresso/55';
---

<div class="flex flex-wrap items-center gap-3">
  {/* App Store — inline Apple mark + official wording */}
  <a
    href={appStoreUrl}
    target="_blank"
    rel="noopener"
    class={`inline-flex items-center gap-2.5 rounded-full px-5 py-2.5 shadow-card transition hover:-translate-y-0.5 ${appStoreClass}`}
  >
    <svg viewBox="0 0 384 512" aria-hidden="true" class="h-6 w-6 fill-current">
      <path
        d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"
      ></path>
    </svg>
    <span class="flex flex-col items-start leading-none">
      <span class="text-[0.62rem] font-medium">Download on the</span>
      <span class="font-display text-base font-bold">App Store</span>
    </span>
  </a>

  {/* Google Play — four-colour mark, "coming soon" (disabled) */}
  <span
    aria-disabled="true"
    class={`inline-flex items-center gap-2.5 rounded-full border px-5 py-2.5 ${playClass}`}
  >
    <svg viewBox="0 0 48 48" aria-hidden="true" class="h-6 w-6">
      <polygon points="12,8 15,24 12,40" fill="#00A1FF"></polygon>
      <polygon points="12,8 32,16 30,24 15,24" fill="#00D365"></polygon>
      <polygon points="12,40 15,24 30,24 32,32" fill="#FF3E44"></polygon>
      <polygon points="32,16 41,24 32,32 30,24" fill="#FFCE00"></polygon>
    </svg>
    <span class="flex flex-col items-start leading-none">
      <span class="text-[0.62rem] font-medium">Coming soon to</span>
      <span class="font-display text-base font-bold">Google Play</span>
    </span>
  </span>
</div>

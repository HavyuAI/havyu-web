---
// ✅ [FEATURE]: FAQ accordion — native <details> (accessible, no JS, SEO-visible).
// Goes at: src/components/FAQ.astro
// Renders from src/data/faqs.ts (same source as the FAQPage schema).
// details name="havyu-faq" = single-open accordion (degrades to independent toggles).
import { faqs } from '../data/faqs';
---

<section id="faq" class="mx-auto max-w-3xl px-6 py-16 md:py-24">
  <h2 class="font-display text-3xl font-black tracking-tight text-espresso md:text-4xl">
    Frequently asked questions
  </h2>
  <p class="mt-4 leading-relaxed text-espresso/70">
    The short version of how Havyu works, what it costs, and what it does with your data.
  </p>

  <div class="mt-10 overflow-hidden rounded-3xl border border-border bg-surface">
    {
      faqs.map((f) => (
        <details class="faq-item" name="havyu-faq">
          <summary>
            <span class="faq-q">{f.q}</span>
            <svg
              class="faq-chevron"
              viewBox="0 0 24 24"
              width="20"
              height="20"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M6 9l6 6 6-6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </summary>
          <p class="faq-a">{f.a}</p>
        </details>
      ))
    }
  </div>
</section>

<style>
  .faq-item:not(:last-child) {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    cursor: pointer;
    list-style: none;
    padding: 20px 24px;
    min-height: 44px;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-q {
    font-family: var(--font-display), sans-serif;
    font-weight: 700;
    font-size: 1.0625rem;
    line-height: 1.4;
    color: var(--color-espresso);
  }

  .faq-chevron {
    flex: 0 0 auto;
    color: var(--color-espresso-faded);
    transition: transform 0.2s ease;
  }
  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-a {
    padding: 0 24px 22px;
    margin: 0;
    max-width: 60ch;
    line-height: 1.6;
    color: var(--color-espresso);
    opacity: 0.72;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-chevron {
      transition: none;
    }
  }
</style>
